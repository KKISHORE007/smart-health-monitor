# ─────────────────────────────────────────────────────────────────────────────
# HealthWatch Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL — provided automatically by Vercel Postgres
# (Vercel injects these when you link a Postgres database in the dashboard)
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# JWT Secret — generate with: openssl rand -base64 64
JWT_SECRET="replace-with-a-long-random-secret-string"

# Node environment
NODE_ENV="development"
